# Database
DATABASE_URL=postgresql://ktm_user:ktm_password@localhost:5432/ktm_digital

# Server
PORT=3001
NODE_ENV=development

# Auth (session JWT - for login, NOT credential signing)
JWT_SECRET=your-session-jwt-secret-here

# Issuer (credential signing - ES256K secp256k1)
ISSUER_PRIVATE_KEY=your-secp256k1-private-key-hex
ISSUER_URL=http://localhost:3000

# Blockchain
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
CONTRACT_ADDRESS=your-deployed-contract-address
